{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--allowed-origins", "http://localhost:4200;http://localhost:8080",
        "--blocked-origins", "https://*",
        "--isolated",
        "--sandbox",
        "--block-service-workers",
        "--caps", "vision"
      ]
    }
  }
}
